FROM node:22-alpine AS build

WORKDIR /src
ARG VITE_BACKEND_URL
ARG VITE_AUTHENTIK_ISSUER_URL
ARG VITE_AUTHENTIK_CLIENT_ID
ARG VITE_AUTHENTIK_REDIRECT_URL
ENV VITE_BACKEND_URL=$VITE_BACKEND_URL
ENV VITE_AUTHENTIK_ISSUER_URL=$VITE_AUTHENTIK_ISSUER_URL
ENV VITE_AUTHENTIK_CLIENT_ID=$VITE_AUTHENTIK_CLIENT_ID
ENV VITE_AUTHENTIK_REDIRECT_URL=$VITE_AUTHENTIK_REDIRECT_URL
COPY package.json ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:1.29-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/dist /usr/share/nginx/html
EXPOSE 80
